        { "jp": "垢", "kana": "あか", "zh": "污垢", "level": "N1", "ex_jp": "手の垢を落とす。", "ex_zh": "把手上的污垢洗掉。" },
        { "jp": "亜科", "kana": "あか", "zh": "亞科", "level": "N1", "ex_jp": "この植物は同じ亜科に属する。", "ex_zh": "這種植物屬於同一亞科。" },
        { "jp": "銅", "kana": "あかがね", "zh": "銅", "level": "N1", "ex_jp": "昔は銅が広く使われた。", "ex_zh": "以前銅被廣泛使用。" },
