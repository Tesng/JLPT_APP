        { "jp": "嗚呼", "kana": "ああ", "zh": "啊；哎呀", "level": "N1", "ex_jp": "ああ、やっと終わった。", "ex_zh": "啊，終於結束了。" },
        { "jp": "相", "kana": "あい", "zh": "相；彼此；關係", "level": "N1", "ex_jp": "二人の相が悪い。", "ex_zh": "兩人的關係不好。" },
