[
    { "jp": "食べる", "kana": "たべる", "zh": "吃", "level": "N5", "ex_jp": "私はりんごを食べる。", "ex_zh": "我吃蘋果。" },
    { "jp": "飲む", "kana": "のむ", "zh": "喝", "level": "N5", "ex_jp": "毎日水をたくさん飲む。", "ex_zh": "每天喝很多水。" },
    { "jp": "見る", "kana": "みる", "zh": "看", "level": "N5", "ex_jp": "週末は映画を見る。", "ex_zh": "週末看電影。" },
    { "jp": "書く", "kana": "かく", "zh": "寫", "level": "N5", "ex_jp": "手紙を書く。", "ex_zh": "寫信。" },
