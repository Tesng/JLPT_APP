        { "jp": "曖昧", "kana": "あいまい", "zh": "曖昧；含糊", "level": "N1", "ex_jp": "彼の返事は曖昧だ。", "ex_zh": "他的回答很曖昧。" },
        { "jp": "敢えて", "kana": "あえて", "zh": "敢於；特意", "level": "N1", "ex_jp": "私は敢えて反対した。", "ex_zh": "我特意表示反對。" },
